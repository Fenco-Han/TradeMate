{
  "name": "trademate",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:api": "go run ./services/api/cmd/api",
    "dev:worker": "go run ./services/api/cmd/worker -mode loop -interval 10s",
    "worker:once": "go run ./services/api/cmd/worker -mode once",
    "dev:web": "pnpm --filter @trademate/web dev",
    "dev:extension": "pnpm --filter @trademate/extension dev",
    "migrate:up": "go run ./services/api/cmd/migrate -action up",
    "migrate:down": "go run ./services/api/cmd/migrate -action down",
    "migrate:reset": "go run ./services/api/cmd/migrate -action reset -seed",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test"
  }
}
